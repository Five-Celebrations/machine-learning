import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Load the Iris dataset
data = sns.load_dataset('iris')

# Select two numerical columns for scatter plot and correlation calculation
x_col = 'sepal_length'
y_col = 'petal_length'

# Compute Pearson Correlation
correlation = data[['sepal_length', 'petal_length']].corr(method='pearson')

print("Pearson Correlation Coefficient:")
print(correlation)

# Compute Covariance Matrix
covariance = data[['sepal_length', 'petal_length']].cov()

print("\nCovariance Matrix:")
print(covariance)

# Create Scatter Plot
plt.figure(figsize=(8, 5))
plt.scatter(data[x_col], data[y_col])
plt.xlabel(x_col)
plt.ylabel(y_col)
plt.title(f"Scatter Plot of {x_col} vs {y_col}")
plt.show()

# Calculate covariance and correlation matrix for all numerical columns
data_co = data.iloc[:, :-1]  # Exclude species column

covariance_matrix = data_co.cov()
print("\nCovariance Matrix:")
print(covariance_matrix)

correlation_matrix = data_co.corr()
print("\nCorrelation Matrix:")
print(correlation_matrix)

# Visualize correlation matrix using heatmap
plt.figure(figsize=(8, 5))
sns.heatmap(correlation_matrix, annot=True, cmap='coolwarm')
plt.title("Correlation Matrix")
plt.show()
