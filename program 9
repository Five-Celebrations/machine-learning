import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.datasets import load_breast_cancer
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import silhouette_score, adjusted_rand_score

# Load and scale data
data = load_breast_cancer()
X = StandardScaler().fit_transform(data.data)

# K-Means clustering
y_pred = KMeans(n_clusters=2, random_state=42).fit_predict(X)

# Evaluation
print("Silhouette Score:", round(silhouette_score(X, y_pred), 3))
print("Adjusted Rand Index:", round(adjusted_rand_score(data.target, y_pred), 3))

# PCA for visualization
X_pca = PCA(n_components=2).fit_transform(X)

# K-Means clusters
sns.scatterplot(x=X_pca[:,0], y=X_pca[:,1], hue=y_pred, palette="coolwarm")
plt.title("K-Means Clustering Result")
plt.show()

# True labels
sns.scatterplot(x=X_pca[:,0], y=X_pca[:,1], hue=data.target, palette="Set2")
plt.title("True Labels")
plt.show()
